# Rename this file to .env and fill in your API keys.

# Required for the default configuration (OpenAI LLM + FAL image generation)
OPENAI_KEY=sk-...
FAL_KEY=fal_...

# Optional — Anthropic Claude models
ANTHROPIC_KEY=sk-ant-...

# Optional — Google Gemini / Vertex AI
GOOGLE_API_KEY=...
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1
